# Discord Bot Configuration
# Get your bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_bot_token_here

# Optional: Guild ID for faster command sync during development
# Remove or leave empty for global command sync (takes up to 1 hour)
GUILD_ID=

# Database Configuration
# Replace 'your_secure_password_here' with the password you set during PostgreSQL setup
DATABASE_URL=postgresql://valmbot:your_secure_password_here@localhost/vegaassassinsqueue
# Dedicated PostgreSQL schema for this bot to avoid table conflicts
DB_SCHEMA=vega_assassins_matchmaking

# Queue Channel ID - The channel where the queue UI will be posted automatically on bot startup
# Right-click a channel in Discord and click "Copy Channel ID" (requires Developer Mode enabled)
QUEUE_CHANNEL_ID=

# Match Category ID - The category where match channels will be created
# Right-click a category in Discord and click "Copy Category ID" (requires Developer Mode enabled)
MATCH_CATEGORY_ID=

# Logs Channel ID - The channel where match results will be logged
# Right-click a channel in Discord and click "Copy Channel ID" (requires Developer Mode enabled)
LOGS_CHANNEL_ID=

# Queue Results Channel ID - The channel where match results with MVP voting will be posted
# Right-click a channel in Discord and click "Copy Channel ID" (requires Developer Mode enabled)
QUEUE_RESULTS_CHANNEL_ID=

# Leaderboard Channel ID - The channel where the persistent leaderboard is displayed
# Right-click a channel in Discord and click "Copy Channel ID" (requires Developer Mode enabled)
LEADERBOARD_CHANNEL_ID=

# Gemini API Configuration (Required for OCR screenshot processing)
# Get your API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Matchmaking Configuration (for future use)
MAX_QUEUE_SIZE=10
MATCH_SIZE=10
QUEUE_TIMEOUT=300



